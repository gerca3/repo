import math


a, b = map(int, input("Введите границы отрезка: ").split())
h = int(input("Введите шаг: "))
for x in range(a, b+1, h):
    if x == 0:
        print("Котангенcа нуля не существует")
        continue
    Func = (math.cos(x) / math.sin(x)) + 1
    print(f"Значение функции: {x} Ответ: {Func:.4f}")
